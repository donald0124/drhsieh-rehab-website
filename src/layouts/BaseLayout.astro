---
import StickyFooter from "../components/StickyFooter.astro";
import "../styles/base.css"; // 1. 先引入地基 (變數 + Tailwind)
import "../styles/style.css"; // 2. 再引入您的舊樣式 (這樣舊樣式才能吃到變數)
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import AnnouncementBanner from "../components/AnnouncementBanner.astro";

// 1. (修改) 擴充 Props 介面，加入可選的 ogImage 與 ogType
export interface Props {
    title: string;
    description: string;
    ogImage?: string; // 讓 index.astro 可以傳入專屬的 OG 圖片
    ogType?: string;  // 預設 "website"，文章頁傳入 "article"
}

// 2. (修改) 接收 Props，並為 ogImage 設定 "預設圖片"
//    (如果 index.astro 沒傳 ogImage，就會使用這張)
const {
    title,
    description,
    ogImage = "/images/default-og-image-1200x630.jpg", // (重要) 請換成您預設圖的路徑
    ogType = "website",
} = Astro.props;

// 3. (新增) 獲取標準網址 (Canonical URL)
// 注意：Astro.site 必須在 astro.config.mjs 中設定
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// 4. (新增) 產生 OG 圖片的 "絕對路徑" (Line/Messenger 必需)
// Astro.site 必須在 astro.config.mjs 中設定
const absoluteOgImageURL = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="zh-TW">
    <head>
        <!-- Google tag (gtag.js) -->
        <script
            is:inline
            async
            src="https://www.googletagmanager.com/gtag/js?id=G-QKK5EJVJ8K"
        ></script>
        <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
                dataLayer.push(arguments);
            }
            gtag("js", new Date());

            gtag("config", "G-QKK5EJVJ8K");
        </script>

        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <!-- Hero 圖片預載：提前告知瀏覽器抓取 LCP 圖片，改善首頁 Core Web Vitals -->
        {
            Astro.url.pathname === "/" && (
                <link
                    rel="preload"
                    as="image"
                    href="/images/hero-cover.jpg"
                    fetchpriority="high"
                />
            )
        }

        <!-- 網站結構化資料  這段 JSON-LD 有助於搜尋引擎正確顯示網站名稱 -->
        {
            Astro.url.pathname === "/" && (
                <script
                    type="application/ld+json"
                    set:html={JSON.stringify({
                        "@context": "https://schema.org",
                        "@type": "WebSite",
                        name: "謝明福復健科診所",
                        url: "https://drhsieh-rehab.com/",
                        alternateName: ["謝明福復健科", "drhsieh-rehab.com"],
                    })}
                />
            )
        }

        <!-- 醫療機構結構化資料  這段 JSON-LD 有助於搜尋引擎理解您的診所資訊 -->
        <script type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@type": "MedicalClinic",
                "name": "謝明福復健科診所",
                "image": "https://drhsieh-rehab.com/images/clinic-outside.jpg",
                "@id": "https://drhsieh-rehab.com/#clinic",
                "url": "https://drhsieh-rehab.com/",
                "telephone": "+886-2-2671-8910",
                "medicalSpecialty": "PhysicalMedicine",
                "physician": { "@id": "https://drhsieh-rehab.com/#doctor" },
                "address": {
                    "@type": "PostalAddress",
                    "streetAddress": "中華路22號2樓",
                    "addressLocality": "三峽區",
                    "addressRegion": "新北市",
                    "postalCode": "237",
                    "addressCountry": "TW"
                },
                "geo": {
                    "@type": "GeoCoordinates",
                    "latitude": "24.9326845",
                    "longitude": "121.3739576"
                },
                "currenciesAccepted": "TWD",
                "paymentAccepted": "現金",
                "sameAs": [
                    "https://www.facebook.com/Top.rehabilitation.center",
                    "https://maps.app.goo.gl/Hn1g21m9DsVVTFQ97"
                ]
            }
        </script>

        <!-- 醫師個人結構化資料  讓 AI 引擎識別謝明福院長的專業資歷與權威性 -->
        <script type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@type": "Person",
                "@id": "https://drhsieh-rehab.com/#doctor",
                "name": "謝明福",
                "honorificPrefix": "Dr.",
                "jobTitle": "復健科主治醫師、院長",
                "description": "擁有30年臨床治療經驗的復健科專科醫師，專長疼痛治療、肌筋膜炎、運動傷害、肩頸腰背疼痛診療。",
                "worksFor": { "@type": "MedicalClinic", "@id": "https://drhsieh-rehab.com/#clinic" },
                "alumniOf": [
                    {
                        "@type": "EducationalOrganization",
                        "name": "國防醫學院",
                        "description": "醫學士"
                    },
                    {
                        "@type": "EducationalOrganization",
                        "name": "中國醫藥大學",
                        "description": "針灸學分班"
                    }
                ],
                "hasCredential": [
                    {
                        "@type": "EducationalOccupationalCredential",
                        "credentialCategory": "專科醫師",
                        "recognizedBy": {
                            "@type": "Organization",
                            "name": "台灣復健醫學會"
                        }
                    }
                ],
                "affiliation": [
                    {
                        "@type": "Organization",
                        "name": "三軍總醫院復健部",
                        "description": "住院醫師、總醫師、主治醫師"
                    },
                    {
                        "@type": "CollegeOrUniversity",
                        "name": "國防醫學院復健醫學系",
                        "description": "臨床助理教授"
                    },
                    {
                        "@type": "CollegeOrUniversity",
                        "name": "University of Pennsylvania",
                        "description": "軟組織疼痛中心臨床研究員"
                    },
                    {
                        "@type": "Hospital",
                        "name": "台大醫院復健醫學部",
                        "description": "進修醫師"
                    },
                    {
                        "@type": "Hospital",
                        "name": "台北榮民總醫院復健醫學部",
                        "description": "進修醫師"
                    }
                ],
                "knowsAbout": [
                    "復健醫學",
                    "疼痛治療",
                    "肌筋膜炎",
                    "運動傷害",
                    "針灸",
                    "軟組織疼痛",
                    "骨科術後復健",
                    "肩頸痛",
                    "腰背痛",
                    "膝痛"
                ],
                "image": "https://drhsieh-rehab.com/images/dr-hsiehmf.jpg",
                "url": "https://drhsieh-rehab.com/"
            }
        </script>

        <meta property="og:site_name" content="謝明福復健科診所" />

        <title>{title}</title>
        <meta name="description" content={description} />

        <link rel="canonical" href={canonicalURL.href} />

        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalURL.href} />
        <meta property="og:type" content={ogType} />

        <meta property="og:locale" content="zh_TW" />
        <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={title} />

        <link
            rel="icon"
            type="image/png"
            href="/favicon/favicon-96x96.png"
            sizes="96x96"
        />
        <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
        <link rel="shortcut icon" href="/favicon/favicon.ico" />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/favicon/apple-touch-icon.png"
        />
        <meta name="apple-mobile-web-app-title" content="謝明福復健科診所" />
        <link rel="manifest" href="/favicon/site.webmanifest" />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap"
            rel="stylesheet"
        />

        <slot name="head" />
    </head>

    <body>
        <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-primary focus:text-white focus:rounded-lg focus:shadow-lg">
            跳至主要內容
        </a>

        <Header />
        <AnnouncementBanner />

        <main id="main-content">
            <slot />
        </main>

        <Footer />

        <StickyFooter />
    </body>
</html>
