---
// src/components/QA.astro
// (Req 2: 我們匯入剛剛建立的 "樣板")
import QAItem from './QAItem.astro';

// (Req 2: 未來您要新增/修改 Q&A，"只需要" 在這裡編輯)
const qaList = [
  {
    question: "Q: 初診可以預約掛號嗎?",
    answer: `<p>A: 本診所一律採現場掛號，毋需預約。初診請於門診時段結束前 20 分鐘報到。</p>`
  },
  {
    question: "Q: 看診時忘了帶健保卡怎麼辦？",
    answer: `<p>A: 若忘了攜帶健保卡，需支付押金NT$500元。隔天起十日內(含例假日)持收據正本、健保卡及其他優待證件，於掛號櫃檯辦理退費手續。</p>`
  },
  {
    question: "Q: 看一次門診可以做幾次復健？有期限嗎？",
    answer: `<p>A: 依據健保局規定，每次門診後可進行六次復健治療，需於治療日起30天內完成，逾期需重新掛號。第二次至第六次復健治療，每次需繳交健保部分負擔50元。請注意，所有復健療程皆須經由醫師看診評估後才能安排。為確保療效，建議您安排固定時間前來，並請務必於復健治療時段結束前30分鐘報到。</p>`
  },
  {
    question: "Q: 初診流程是什麼？第一次看診需要帶什麼？",
    answer: `<p>A: 初診請攜帶健保卡，於診所掛號櫃檯現場掛號後等候叫號。謝院長會親自問診、評估症狀，並視需要安排後續復健治療計畫。建議您事先記錄症狀發生時間、部位與誘發動作，有助於提升看診效率。</p>`
  },
  {
    question: "Q: 健保有給付復健治療嗎？看診費用如何計算？",
    answer: `<p>A: 本診所為健保特約診所，一般門診與復健治療均可申請健保給付，僅需繳交健保部分負擔費用。具體費用依健保局規定計算，如有疑問可於掛號時向診所人員詢問。</p>`
  },
  {
    question: "Q: 針極肌肉內電刺激 (NEIMS) 是什麼治療？",
    answer: `<p>A: NEIMS（針極肌肉內電刺激）是謝明福院長具20年以上操作經驗的特色治療，透過細針精準定位深層肌筋膜激痛點，配合電刺激使緊繃肌肉放鬆，有效處理傳統物理治療難以觸及的慢性疼痛根源。詳細說明請參閱：<a href="/treatments/neims/" class="underline text-primary hover:text-primary-dark">第一次 NEIMS 治療前必看指南</a>。</p>`
  },
  {
    question: "Q: 謝院長的治療與一般診所的復健有什麼不同？",
    answer: `<p>A: 謝院長強調「精準診斷、整合治療」，不僅提供傳統物理治療，更整合 NEIMS 針極肌肉內電刺激、直線偏極光、關節玻尿酸注射與葡萄糖水增生注射等進階療法。每位患者的治療計畫均由謝院長親自評估制定，針對疼痛根源而非僅緩解症狀。</p>`
  },
  {
    question: "Q: 診所提供哪些治療儀器與療法？",
    answer: `<p>A: 診所配備超音波治療、電療、熱療、牽引等標準物理治療儀器，並提供謝院長專長的 NEIMS 針極肌肉內電刺激、直線偏極光（SuperLizer）、關節玻尿酸注射及葡萄糖水增生注射療法，適合肌筋膜疼痛、慢性疼痛與骨科術後復健等多種情況。</p>`
  },
  {
    question: "Q: 症狀改善後還需要繼續回診嗎？",
    answer: `<p>A: 這取決於個別症狀與治療進展，謝院長會在每次看診時評估恢復狀況並給予建議。部分患者在完成療程後即可結案，另有部分慢性疼痛患者可能需要定期追蹤，以維持治療效果並預防復發。</p>`
  },
  {
    question: "Q: 診所位於哪裡？從三峽或鶯歌市區方便前來嗎？",
    answer: `<p>A: 診所位於新北市三峽區中華路22號2樓，距離三峽老街約5分鐘車程，鶯歌居民可沿復興路行駛約15分鐘抵達中華路右轉。診所附近有停車空間，詳細交通資訊請參考官網就診資訊頁面或洽詢診所。</p>`
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": qaList.map(qa => ({
    "@type": "Question",
    "name": qa.question.replace(/^Q:\s*/, ''),
    "acceptedAnswer": {
      "@type": "Answer",
      "text": qa.answer.replace(/^<p>A:\s*/, '').replace(/<\/p>$/, '')
    }
  }))
};

---
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<div class="qna-section" style="margin-top: 4rem; max-width: 900px; margin-left: auto; margin-right: auto;">
    <h3 class="text-2xl font-bold text-center text-primary-dark mb-6">常見 Q&A</h3>
    
    <div id="accordion-qa-container" class="space-y-4" style="margin-top: 2rem;">
        
        {qaList.map(qa => (
          <QAItem question={qa.question}>
            <Fragment set:html={qa.answer} />
          </QAItem>
        ))}

    </div>
</div>