---
// 這裡僅載入 CSS 及準備元件容器。
// 因為您的專案是 Astro 靜態網站 (SSG)，若使用 Build time Fetch 會導致資料直到下次部署才更新。
// 因此我幫您實作了 Client-Side Fetch 並搭配 localSotrage 快取 12 小時。
// 此元件完全不需要依賴 React 即可運作於您目前的 Astro 專案。
---

<drhsieh-announcement
  class="block sticky top-[70px] lg:top-[80px] z-[890] shadow-sm"
></drhsieh-announcement>

<style is:global>
  /* 跑馬燈動畫 */
  @keyframes astro-marquee {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(-100%);
    }
  }
  .animate-astro-marquee {
    animation: astro-marquee 30s linear infinite;
  }
  .pause-on-hover:hover .animate-astro-marquee {
    animation-play-state: paused;
  }

  /* 彈跳視窗動畫與滾動鎖定 */
  .fade-in {
    animation: fadeIn 0.15s ease-out forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .slide-up {
    animation: slideUp 0.15s ease-out forwards;
  }
  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  :global(body.modal-open) {
    overflow: hidden;
  }
</style>

<script>
  // @ts-nocheck
  class AnnouncementBanner extends HTMLElement {
    constructor() {
      super();
      this.API_URL =
        "https://script.googleusercontent.com/macros/echo?user_content_key=AWDtjMUijMkpvLbpELmZy2rDj1kCdfra-rdmjlqjMNFHNTqs1dHXRFUDHHWHYJyg6Penc37EewxIevybo9O05ywLvd6AhN4fp4Iz3b3L1a42B4R7OBZXGkGzeHOJsWZJg4SXdTK4CnaJnAwYsQcTHOkhSxwnMtX7hVdjWuatdeIdf8rbfJGP3-tqolCiGUs7scBHit-w_iHhQ0KmoDdUH0zJ6zhAHPWTDeqDHApD3JAPzptFqlB_wDX0jgqXiww7D16N4HA84--2M2JDasHnxZcO96FnPaeYbw&lib=M2RT9uHoxt1wB_xGvFK9YgeOW2yHdl2sE";
      this.CACHE_KEY = "drhsieh_announcement_cache";
      this.CACHE_MINUTES = 0.2; //720; // 12 小時
      this.isOpen = false;
      this.announcements = [];
    }

    async connectedCallback() {
      await this.loadData();
      if (this.announcements.length > 0) {
        this.render();
      }
    }

    async loadData() {
      try {
        const cached = localStorage.getItem(this.CACHE_KEY);
        if (cached) {
          const { data, timestamp } = JSON.parse(cached);
          if (Date.now() - timestamp < this.CACHE_MINUTES * 60 * 1000) {
            this.filterActive(data);
            return;
          }
        }

        const res = await fetch(this.API_URL);
        const data = await res.json();

        localStorage.setItem(
          this.CACHE_KEY,
          JSON.stringify({
            data,
            timestamp: Date.now(),
          }),
        );

        this.filterActive(data);
      } catch (err) {
        console.error("Failed to load announcements:", err);
      }
    }

    filterActive(data) {
      const now = new Date();
      // 確保將當前時間補正到台灣時區 (+8)
      const nowTwUtc = now.getTime() + now.getTimezoneOffset() * 60000;
      const nowTw = new Date(nowTwUtc + 3600000 * 8);

      this.announcements = data.filter((item) => {
        if (!item.startDate || !item.endDate) return false;

        const [sy, sm, sd] = item.startDate.split("-");
        const [ey, em, ed] = item.endDate.split("-");
        const start = new Date(`${sy}-${sm}-${sd}T00:00:00+08:00`);
        const end = new Date(`${ey}-${em}-${ed}T23:59:59+08:00`);

        const showTime = new Date(start.getTime() - 7 * 86400000);
        return nowTw >= showTime && nowTw <= end;
      });
    }

    getStyles(status) {
      if (status === "提早休診")
        return {
          bg: "bg-orange-100",
          text: "text-orange-800",
          border: "border-l-orange-500",
          icon: "⚠️",
        };
      if (status === "全日休診")
        return {
          bg: "bg-red-100",
          text: "text-red-800",
          border: "border-l-red-500",
          icon: "🔴",
        };
      if (status === "特別開診")
        return {
          bg: "bg-green-100",
          text: "text-green-800",
          border: "border-l-green-500",
          icon: "🟢",
        };
      return {
        bg: "bg-blue-100",
        text: "text-blue-800",
        border: "border-l-blue-500",
        icon: "ℹ️",
      };
    }

    render() {
      const primaryStyle = this.getStyles(this.announcements[0].status);

      const itemsHtml = this.announcements
        .map((a) => {
          const s = this.getStyles(a.status);
          return `<span class="flex items-center gap-1.5 font-medium whitespace-nowrap text-xs sm:text-sm">${s.icon} ${a.message}</span>`;
        })
        .join("");

      // 1. 先使用靜態置中排版渲染
      this.innerHTML = `
        <div id="astro-banner" class="w-full py-1.5 px-4 cursor-pointer relative z-40 transition-colors hover:brightness-95 overflow-hidden flex items-center justify-center ${primaryStyle.bg} ${primaryStyle.text}">
          <div id="banner-content" class="flex justify-center gap-8 items-center whitespace-nowrap max-w-7xl mx-auto w-full">
            ${itemsHtml}
          </div>
        </div>
      `;

      this.querySelector("#astro-banner").addEventListener("click", () =>
        this.openModal(),
      );

      // 2. 佈局完成後測量寬度，如果無法在一行顯示完畢則裝載跑馬燈
      requestAnimationFrame(() => {
        const content = this.querySelector("#banner-content");

        // 判斷真實內容寬度 (scrollWidth) 是否大於外層可視寬度 (clientWidth)
        if (content && content.scrollWidth > content.clientWidth + 1) {
          content.className =
            "w-full flex overflow-hidden pause-on-hover max-w-7xl mx-auto items-center";
          content.innerHTML = `
            <div class="animate-astro-marquee flex gap-8 shrink-0 pr-8 items-center">${itemsHtml}</div>
            <div class="animate-astro-marquee flex gap-8 shrink-0 pr-8 items-center" aria-hidden="true">${itemsHtml}</div>
          `;
        }
      });
    }

    openModal() {
      if (document.getElementById("announcement-modal")) return;

      const modal = document.createElement("div");
      modal.id = "announcement-modal";
      modal.className = `fixed inset-0 z-50 flex items-center justify-center p-4 fade-in`;

      let listHtml = this.announcements
        .map((a) => {
          const sx = this.getStyles(a.status);
          const dateDisplay =
            a.startDate === a.endDate
              ? a.startDate
              : `${a.startDate} ~ ${a.endDate}`;

          let hoursHtml = "";
          if (a.doctorHours || a.rehabHours) {
            let doc = a.doctorHours
              ? `<div class="flex gap-2"><span class="text-gray-500 shrink-0 font-medium">門診時間：</span><span class="text-gray-700">${a.doctorHours}</span></div>`
              : "";
            let rehab = a.rehabHours
              ? `<div class="flex gap-2"><span class="text-gray-500 shrink-0 font-medium">復健時間：</span><span class="text-gray-700">${a.rehabHours}</span></div>`
              : "";
            hoursHtml = `<div class="text-sm bg-gray-50 p-3 rounded-md space-y-1.5 border border-gray-100 mt-2">${doc}${rehab}</div>`;
          }

          return `
          <div class="p-4 rounded-lg border shadow-sm bg-white border-l-4 ${sx.border}">
             <div class="flex flex-wrap items-center gap-2 mb-2">
               <span class="px-2 py-1 text-xs font-semibold rounded ${sx.bg} ${sx.text}">${a.status}</span>
               <span class="text-sm font-semibold text-gray-500">${dateDisplay}</span>
             </div>
             <p class="text-gray-800 font-medium whitespace-pre-line leading-relaxed mb-3">${a.message}</p>
             ${hoursHtml}
          </div>
         `;
        })
        .join("");

      modal.innerHTML = `
        <div class="absolute inset-0 bg-black/50 backdrop-blur-sm transition-opacity" id="modal-overlay"></div>
        <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-lg overflow-hidden flex flex-col max-h-[90vh] slide-up">
          <div class="p-4 border-b border-gray-100 flex justify-between items-center bg-gray-50/80">
            <h2 class="text-xl font-bold text-gray-800">最新門診公告</h2>
            <button id="modal-close" class="text-gray-400 hover:text-gray-600 transition-colors p-2 -mr-2 rounded-full hover:bg-gray-200">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </div>
          <div class="p-4 overflow-y-auto w-full space-y-4">
             ${listHtml}
          </div>
          <div class="p-4 border-t border-gray-100 text-center bg-gray-50/50">
            <button id="modal-ok" class="px-6 py-2 bg-gray-800 text-white font-medium rounded-lg hover:bg-gray-700 transition-colors w-full sm:w-auto min-w-[120px]">
              我知道了
            </button>
          </div>
        </div>
      `;

      document.body.appendChild(modal);
      document.body.classList.add("modal-open");

      const closeModal = () => {
        modal.remove();
        document.body.classList.remove("modal-open");
      };

      modal
        .querySelector("#modal-overlay")
        .addEventListener("click", closeModal);
      modal.querySelector("#modal-close").addEventListener("click", closeModal);
      modal.querySelector("#modal-ok").addEventListener("click", closeModal);
    }
  }

  customElements.define("drhsieh-announcement", AnnouncementBanner);
</script>
