---
// src/components/Treatments.astro
---

<section
    id="treatments"
    class="py-16 md:py-20 bg-white relative overflow-hidden"
>
    <div class="container mx-auto px-4 max-w-5xl">

        <!-- 標題 -->
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-bold text-heading mb-4 relative inline-block">
                治療項目
                <span class="absolute -bottom-2 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-primary to-transparent opacity-50"></span>
            </h2>
            <p class="text-lg text-gray-600 max-w-2xl mx-auto mt-4">
                謝明福復健科診所提供復健科、疼痛處理、運動醫學等多元治療項目，由醫師評估後制定個人化療程。
            </p>
        </div>

        <!-- 治療原則 -->
        <div
            class="mb-16 max-w-4xl mx-auto bg-gray-50 rounded-3xl p-8 md:p-12 shadow-sm border border-gray-100 relative overflow-hidden"
        >
            <div class="relative z-10">
                <h3 class="text-2xl md:text-3xl font-bold text-gray-800 mb-8 text-center">
                    我們的治療原則：<span class="text-primary">精準</span> 與 <span class="text-primary">整合</span>
                </h3>

                <div class="grid md:grid-cols-2 gap-8">
                    <div class="flex gap-4">
                        <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-primary text-2xl font-bold flex-shrink-0">
                            1
                        </div>
                        <div>
                            <h4 class="text-xl font-bold text-gray-900 mb-2">專業診斷</h4>
                            <p class="text-gray-600 leading-relaxed">
                                醫師將透過專業理學檢查，找到疼痛的真正根源（肌肉、肌腱、韌帶、神經、關節或其他肇因）。
                            </p>
                        </div>
                    </div>

                    <div class="flex gap-4">
                        <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-primary text-2xl font-bold flex-shrink-0">
                            2
                        </div>
                        <div>
                            <h4 class="text-xl font-bold text-gray-900 mb-2">整合性治療</h4>
                            <p class="text-gray-600 leading-relaxed">
                                結合多元儀器物理治療及院長專長（如<a
                                    href="/blog/superlizer/"
                                    class="text-primary underline font-medium"
                                    >直線偏極光</a
                                > / <a
                                    href="/treatments/neims/"
                                    class="text-primary underline font-medium"
                                    >針極肌肉內電刺激</a
                                >）進行治療。
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <!-- 裝飾圓圈 -->
            <div class="absolute -top-24 -right-24 w-48 h-48 bg-blue-50 rounded-full blur-3xl opacity-50"></div>
        </div>

        <!-- A 類：院長特色治療 -->
        <div class="mb-16">
            <h3 class="text-xl font-bold text-gray-700 mb-6 flex items-center gap-3">
                <span class="w-8 h-8 rounded-full bg-primary text-white text-sm font-bold flex items-center justify-center flex-shrink-0">A</span>
                院長特色治療
            </h3>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Card 1: NEIMS -->
                <div class="group relative bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <div class="w-14 h-14 bg-blue-50 rounded-2xl flex items-center justify-center text-primary mb-6 group-hover:scale-110 transition-transform duration-300">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                    </div>
                    <h4 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-primary transition-colors">
                        針極肌肉內電刺激
                    </h4>
                    <p class="text-gray-500 text-xs mb-3 font-medium tracking-wide">Needle Electrical Intramuscular Stimulation, NEIMS</p>
                    <p class="text-gray-600 text-sm mb-4 leading-relaxed">
                        使用鐵氟龍絕緣單極針，將電刺激精準導至深層肌筋膜激痛點，由院長親自評估執行。
                    </p>
                    <div class="flex flex-wrap gap-1.5 mb-5">
                        {["慢性疼痛", "肌筋膜炎", "坐骨神經痛", "頸肩腰背痛", "運動傷害", "術後沾黏", "五十肩", "網球肘"].map((tag) => (
                            <span class="text-xs bg-blue-50 text-primary-dark px-2 py-0.5 rounded-full border border-blue-100">{tag}</span>
                        ))}
                    </div>
                    <a
                        href="/treatments/neims/"
                        class="inline-flex items-center text-primary font-bold text-sm hover:gap-2 transition-all"
                        aria-label="了解 NEIMS 治療方式與就診流程"
                    >
                        了解治療方式 <span class="ml-1">→</span>
                    </a>
                </div>

                <!-- Card 2: Superlizer -->
                <div class="group relative bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <div class="w-14 h-14 bg-orange-50 rounded-2xl flex items-center justify-center text-orange-500 mb-6 group-hover:scale-110 transition-transform duration-300">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
                        </svg>
                    </div>
                    <h4 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-orange-600 transition-colors">
                        直線偏極光治療
                    </h4>
                    <p class="text-gray-500 text-xs mb-3 font-medium tracking-wide">Superlizer</p>
                    <p class="text-gray-600 text-sm mb-4 leading-relaxed">
                        輔助緩解肌肉痠痛、促進軟組織修復與循環改善。
                    </p>
                    <a
                        href="/blog/superlizer/"
                        class="inline-flex items-center text-orange-500 font-bold text-sm hover:gap-2 transition-all"
                        aria-label="了解直線偏極光治療"
                    >
                        了解更多 <span class="ml-1">→</span>
                    </a>
                </div>

                <!-- Card 3: 玻尿酸 -->
                <div class="group relative bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <div class="w-14 h-14 bg-teal-50 rounded-2xl flex items-center justify-center text-teal-600 mb-6 group-hover:scale-110 transition-transform duration-300">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                        </svg>
                    </div>
                    <h4 class="text-xl font-bold text-gray-800 mb-3 group-hover:text-teal-600 transition-colors">
                        關節玻尿酸注射
                    </h4>
                    <p class="text-gray-600 text-sm leading-relaxed">
                        補充關節潤滑液，適用於退化性關節炎，增加活動潤滑度。
                    </p>
                </div>

                <!-- Card 4: 葡萄糖水 -->
                <div class="group relative bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <div class="w-14 h-14 bg-pink-50 rounded-2xl flex items-center justify-center text-pink-500 mb-6 group-hover:scale-110 transition-transform duration-300">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                        </svg>
                    </div>
                    <h4 class="text-xl font-bold text-gray-800 mb-3 group-hover:text-pink-600 transition-colors">
                        葡萄糖水增生注射
                    </h4>
                    <p class="text-gray-600 text-sm leading-relaxed">
                        利用高濃度葡萄糖水刺激軟組織，輔助受傷韌帶與肌腱恢復。
                    </p>
                </div>
            </div>
        </div>

        <!-- B / C / D 類：簡易條列 -->
        <div class="grid md:grid-cols-3 gap-6">
            <!-- B 類：復健中心 -->
            <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
                <h3 class="text-base font-bold text-gray-700 mb-4 flex items-center gap-2">
                    <span class="w-6 h-6 rounded-full bg-primary text-white text-xs font-bold flex items-center justify-center flex-shrink-0">B</span>
                    復健治療
                </h3>
                <ul class="space-y-3">
                    {[
                        { name: "骨科術後復健", desc: "手術後的關節活動度與肌力恢復" },
                        { name: "神經復健", desc: "神經壓迫、麻痺後的功能訓練" },
                        { name: "脊椎復健", desc: "脊椎相關疾患的保守治療與姿勢矯正" },
                        { name: "個別化復健治療", desc: "依患者狀況量身規劃的復健計畫" },
                    ].map(({ name, desc }) => (
                        <li class="flex flex-col">
                            <span class="font-semibold text-gray-800 text-sm">{name}</span>
                            <span class="text-gray-500 text-xs mt-0.5">{desc}</span>
                        </li>
                    ))}
                </ul>
            </div>

            <!-- C 類：疼痛處理 -->
            <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
                <h3 class="text-base font-bold text-gray-700 mb-4 flex items-center gap-2">
                    <span class="w-6 h-6 rounded-full bg-primary text-white text-xs font-bold flex items-center justify-center flex-shrink-0">C</span>
                    疼痛處理
                </h3>
                <ul class="space-y-3">
                    {[
                        { name: "肌筋膜疼痛治療", desc: "激痛點治療，緩解慢性肌肉緊繃" },
                        { name: "肩頸痠痛治療", desc: "頸椎與肩部疼痛的評估與處置" },
                        { name: "坐骨神經痛治療", desc: "神經根壓迫引起的臀腿疼痛" },
                        { name: "退化性關節炎疼痛治療", desc: "關節退化的保守治療與疼痛控制" },
                    ].map(({ name, desc }) => (
                        <li class="flex flex-col">
                            <span class="font-semibold text-gray-800 text-sm">{name}</span>
                            <span class="text-gray-500 text-xs mt-0.5">{desc}</span>
                        </li>
                    ))}
                </ul>
            </div>

            <!-- D 類：運動醫學 -->
            <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
                <h3 class="text-base font-bold text-gray-700 mb-4 flex items-center gap-2">
                    <span class="w-6 h-6 rounded-full bg-primary text-white text-xs font-bold flex items-center justify-center flex-shrink-0">D</span>
                    運動醫學
                </h3>
                <ul class="space-y-3">
                    {[
                        { name: "運動傷害治療", desc: "急慢性運動傷害的評估與復原" },
                        { name: "肌腱炎治療", desc: "板機指、媽媽手、網球肘等肌腱問題" },
                        { name: "肌肉韌帶扭拉傷復健", desc: "扭傷、拉傷的急性處置與功能恢復" },
                        { name: "足底筋膜炎治療", desc: "足跟疼痛的保守治療與體外震波" },
                    ].map(({ name, desc }) => (
                        <li class="flex flex-col">
                            <span class="font-semibold text-gray-800 text-sm">{name}</span>
                            <span class="text-gray-500 text-xs mt-0.5">{desc}</span>
                        </li>
                    ))}
                </ul>
            </div>
        </div>

    </div>
</section>
