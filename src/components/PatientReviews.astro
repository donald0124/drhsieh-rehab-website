        </div>

        <!-- 底部按鈕 -->
        <div
            class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-6"
        >
            <a
                href="https://share.google/D4RIXbD62LxDcVSwc"
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center gap-2 text-primary font-medium hover:text-blue-800 transition-colors"
            >
                <svg
                    class="w-5 h-5"
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <path
                        d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                        fill="#4285F4"></path>
                    <path
                        d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.16v2.84C3.99 20.53 7.7 23 12 23z"
                        fill="#34A853"></path>
                    <path
                        d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.16C1.43 8.55 1 10.22 1 12s.43 3.45 1.16 4.93l3.68-2.84z"
                        fill="#FBBC05"></path>
                    <path
                        d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.16 7.07l3.68 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                        fill="#EA4335"></path>
                </svg>
                查看 Google 上的所有評價
                <svg
                    class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                    ></path></svg
                >
            </a>
            <a
                href="https://g.page/r/Cddgwu6ErPygEAE/review"
                target="_blank"
                rel="noopener noreferrer"
                class="bg-[#002855] hover:bg-blue-900 text-white px-8 py-3 rounded-full font-medium transition-colors flex items-center gap-2 shadow-md hover:shadow-lg"
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"
                    ></path></svg
                >
                撰寫評價
            </a>
        </div>
    </div>
</section>

<script>
    // 在 Astro 中控制「閱讀全文」的展開/收合與左右滑動
    function initReviews() {
        // 先移除舊的按鈕事件避免重複綁定 (特別是在 ViewTransitions 情境下)
        document.querySelectorAll(".read-more-btn").forEach((btn) => {
            const newBtn = btn.cloneNode(true);
            btn.parentNode.replaceChild(newBtn, btn);
        });

        // 判定是否顯示「閱讀全文」按鈕
        const checkOverflow = () => {
            document.querySelectorAll(".review-content").forEach((content) => {
                const btn = content.nextElementSibling;
                if (!btn) return;

                // 檢查是否被 line-clamp 截斷 (實際內容高度 > 可見容器高度)
                // 加上 2px 緩衝避免小數點計算誤差
                if (content.scrollHeight > content.clientHeight + 2) {
                    btn.classList.remove("hidden");
                } else {
                    if (content.classList.contains("line-clamp-3")) {
                        btn.classList.add("hidden");
                    }
                }
            });
        };

        // 給予瀏覽器極短時間完成渲染，以確保能精準計算 scrollHeight
        setTimeout(checkOverflow, 50);

        // 重新綁定展開/收合事件
        document.querySelectorAll(".read-more-btn").forEach((btn) => {
            btn.addEventListener("click", (e) => {
                const button = e.currentTarget;
                const textContainer = button.previousElementSibling;

                if (textContainer.classList.contains("line-clamp-3")) {
                    textContainer.classList.remove("line-clamp-3");
                    button.innerText = "收合";
                } else {
                    textContainer.classList.add("line-clamp-3");
                    button.innerText = "閱讀全文";
                }
            });
        });

        // 綁定桌面左右箭頭
        const carousel = document.getElementById("reviews-carousel");
        const prevBtn = document.getElementById("prev-review");
        const nextBtn = document.getElementById("next-review");

        if (carousel && prevBtn && nextBtn) {
            const scrollAmount = window.innerWidth > 768 ? 360 : 280;

            // 使用複製方式重置按鈕事件
            const newPrev = prevBtn.cloneNode(true);
            const newNext = nextBtn.cloneNode(true);
            prevBtn.parentNode.replaceChild(newPrev, prevBtn);
            nextBtn.parentNode.replaceChild(newNext, nextBtn);

            newPrev.addEventListener("click", () => {
                carousel.scrollBy({ left: -scrollAmount, behavior: "smooth" });
            });
            newNext.addEventListener("click", () => {
                carousel.scrollBy({ left: scrollAmount, behavior: "smooth" });
            });
        }
    }

    // 支援一般載入與 Astro ViewTransitions
    document.addEventListener("DOMContentLoaded", initReviews);
    document.addEventListener("astro:page-load", initReviews);
</script>

<style>
    /* 隱藏滾動條但保留功能 */
    .hide-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .hide-scrollbar {
        -ms-overflow-style: none; /* IE and Edge */
        scrollbar-width: none; /* Firefox */
    }
</style>
