---
import { Image } from 'astro:assets';
import drHsiehmfImg from '../assets/images/dr-hsiehmf.jpg';
import interviewHeroImg from '../assets/images/blog/interview-hero.jpg';
---

<section id="team" class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-4xl font-bold text-center mb-16 text-heading">
            醫師介紹
        </h2>

        <!-- 1. 醫師名片卡 (Profile Card) -->
        <article
            class="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100 flex flex-col md:flex-row max-w-5xl mx-auto mb-20 relative"
        >
            <!-- 背景裝飾 -->
            <div
                class="absolute top-0 right-0 w-64 h-64 bg-primary/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"
            >
            </div>

            <!-- 左側：照片區 -->
            <div class="md:w-2/5 relative min-h-[400px] md:min-h-full">
                <Image
                    src={drHsiehmfImg}
                    alt="謝明福復健科診所院長 - 謝明福醫師"
                    class="absolute inset-0 w-full h-full object-cover object-top"
                    loading="lazy"
                    decoding="async"
                />
                <div
                    class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent md:hidden"
                >
                </div>
                <div class="absolute bottom-6 left-6 text-white md:hidden">
                    <h3 class="text-3xl font-bold">謝明福 院長</h3>
                    <p class="text-lg opacity-90 mt-1">30年臨床治療經驗</p>
                </div>
            </div>

            <!-- 右側：資訊區 -->
            <div class="md:w-3/5 p-8 md:p-12 flex flex-col justify-center">
                <div class="hidden md:block mb-6">
                    <h3 class="text-3xl font-bold text-heading">謝明福 院長</h3>
                    <p class="text-lg text-gray-500 mt-2 font-medium">
                        30年豐富臨床經驗
                    </p>
                </div>

                <div class="grid md:grid-cols-2 gap-8">
                    <!-- 學歷 -->
                    <div>
                        <h4
                            class="text-lg font-bold text-primary mb-4 flex items-center gap-2"
                        >
                            <span class="w-1 h-6 bg-primary rounded-full"
                            ></span>
                            學歷
                        </h4>
                        <ul class="space-y-2 text-gray-600">
                            <li>國防醫學院醫學士</li>
                            <li>中國醫藥大學針灸學分班</li>
                        </ul>
                    </div>

                    <!-- 核心經歷 -->
                    <div>
                        <h4
                            class="text-lg font-bold text-primary mb-4 flex items-center gap-2"
                        >
                            <span class="w-1 h-6 bg-primary rounded-full"
                            ></span>
                            核心經歷
                        </h4>
                        <ul class="space-y-2 text-gray-600">
                            <li>台灣復健醫學會 專科醫師</li>
                            <li>三軍總醫院復健部 住院/總/主治醫師</li>
                            <li>台大、台北榮總復健醫學部 進修醫師</li>
                            <li>國防醫學院復健醫學系 臨床助理教授</li>
                            <li>
                                美國賓州大學(UPENN) 軟組織疼痛中心 臨床研究員
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="mt-8 pt-8 border-t border-gray-100">
                    <p class="text-gray-600 leading-relaxed text-justify">
                        專精於<strong class="text-primary-dark"
                            >「<a
                                href="/blog/neims/"
                                class="underline decoration-2 underline-offset-2 hover:text-primary"
                                >針極肌肉內電刺激治療 (NEIMS)</a
                            >」</strong
                        >。擅長處理肌肉筋膜、軟組織疼痛，為患者提供精準且溫和的治療選擇。
                    </p>
                </div>
            </div>
        </article>

        <!-- 2. 詳細資歷 (Timeline Style) -->
        <div class="max-w-4xl mx-auto mb-20 px-4">
            <h3 class="text-2xl font-bold text-center text-heading mb-10">
                完整資歷程
            </h3>
            <div
                class="relative border-l-2 border-primary/20 space-y-10 pl-8 ml-4 md:ml-0"
            >
                <!-- Item 1 -->
                <div class="relative">
                    <span
                        class="absolute -left-[41px] top-1 w-5 h-5 rounded-full bg-primary border-4 border-white shadow-sm"
                    ></span>
                    <h4 class="text-lg font-bold text-gray-900">現任</h4>
                    <ul class="mt-2 text-gray-600 space-y-1">
                        <li>謝明福復健科診所 院長</li>
                        <li>三軍總醫院復健部 兼任主治醫師</li>
                    </ul>
                </div>
                <!-- Item 2 -->
                <div class="relative">
                    <span
                        class="absolute -left-[41px] top-1 w-5 h-5 rounded-full bg-gray-300 border-4 border-white"
                    ></span>
                    <h4 class="text-lg font-bold text-gray-900">曾任</h4>
                    <ul class="mt-2 text-gray-600 space-y-1 checkbox-list">
                        <li>
                            大台北地區各公家機關特約主治醫師 (國防部、國安局等)
                        </li>
                        <li>國軍桃園總醫院 兼任復健科主治醫師</li>
                        <li>國軍斗六(819)醫院 復健科主治醫師</li>
                        <li>國軍金門花崗石醫院 外科住院醫師</li>
                    </ul>
                </div>
                <!-- Item 3 -->
                <div class="relative">
                    <span
                        class="absolute -left-[41px] top-1 w-5 h-5 rounded-full bg-gray-300 border-4 border-white"
                    ></span>
                    <h4 class="text-lg font-bold text-gray-900">
                        專業成就與媒體報導
                    </h4>
                    <ul class="mt-2 text-gray-600 space-y-1 checkbox-list">
                        <li>2014 商業週刊網路票選百大良醫前五十名</li>
                        <li>《動動腳趾活更久》一書專業審定醫師</li>
                        <li>多次受邀至 警廣、漢聲電台、康健雜誌 專訪</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- 3. 媒體專訪 (Featured Media) -->
        <div class="max-w-5xl mx-auto">
            <h3 class="text-2xl font-bold text-center text-heading mb-10">
                媒體專訪
            </h3>

            <div class="grid md:grid-cols-2 gap-8 items-start">
                <!-- Video Card -->
                <div
                    class="bg-white p-4 rounded-2xl shadow-lg border border-gray-100"
                >
                    <!-- YouTube Facade: 靜態縮圖，點擊後才載入 iframe，避免爬蟲解析 YouTube 錯誤訊息 -->
                    <div class="aspect-video rounded-xl overflow-hidden mb-4 yt-facade" data-videoid="RSbH0PnGA6o">
                        <img
                            src="https://i.ytimg.com/vi/RSbH0PnGA6o/hqdefault.jpg"
                            alt="謝明福院長年代新聞專訪影片縮圖"
                            class="w-full h-full object-cover"
                            loading="lazy"
                            decoding="async"
                            width="480"
                            height="360"
                        />
                        <button class="yt-play-btn" aria-label="播放謝明福院長年代新聞專訪影片">
                            <svg viewBox="0 0 68 48" width="68" height="48" aria-hidden="true"><path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="#f00"/><path d="M45 24 27 14v20" fill="#fff"/></svg>
                        </button>
                    </div>
                    <h4 class="font-bold text-lg text-gray-800 text-center">
                        年代新聞台《聚焦2.0》專訪
                    </h4>
                </div>

                <!-- Article Card -->
                <a
                    href="/blog/top-rehab-doctor-interview-sanxia-clinic/"
                    class="group bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col h-full"
                >
                    <div class="h-48 overflow-hidden relative">
                        <Image
                            src={interviewHeroImg}
                            alt="良醫健康網專訪"
                            class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
                            loading="lazy"
                            decoding="async"
                        />
                        <div
                            class="absolute top-4 left-4 bg-primary text-white text-xs font-bold px-3 py-1 rounded-full shadow-sm"
                        >
                            專訪報導
                        </div>
                    </div>
                    <div class="p-6 flex-1 flex flex-col">
                        <h4
                            class="font-bold text-xl text-gray-800 mb-3 group-hover:text-primary transition-colors"
                        >
                            《良醫健康網》專訪：第一名復健科醫師的堅持
                        </h4>
                        <p class="text-gray-600 text-sm mb-4 line-clamp-3">
                            「止痛藥自己不吃，怎麼開給病人吃？」謝明福院長分享堅持非藥物治療的初衷，以及藏在小診所裡的專業堅持。
                        </p>
                        <span
                            class="text-primary font-medium text-sm mt-auto flex items-center gap-1 group-hover:gap-2 transition-all"
                        >
                            閱讀完整文章 →
                        </span>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    /* Timeline List Bullets */
    .checkbox-list li::before {
        content: "•";
        color: var(--color-primary);
        font-weight: bold;
        display: inline-block;
        width: 1em;
        margin-left: -1em;
    }
    .checkbox-list li {
        padding-left: 1em;
    }

    /* YouTube Facade */
    .yt-facade {
        position: relative;
        cursor: pointer;
        background: #000;
    }
    .yt-facade img {
        display: block;
        transition: opacity 0.2s;
    }
    .yt-facade:hover img {
        opacity: 0.8;
    }
    .yt-play-btn {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        filter: drop-shadow(0 2px 8px rgba(0,0,0,0.5));
        transition: transform 0.2s;
    }
    .yt-facade:hover .yt-play-btn {
        transform: translate(-50%, -50%) scale(1.1);
    }
</style>

<script>
    document.querySelectorAll<HTMLElement>('.yt-facade').forEach((facade) => {
        facade.addEventListener('click', () => {
            const videoId = facade.dataset.videoid;
            const iframe = document.createElement('iframe');
            iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0`;
            iframe.title = '謝明福院長年代新聞專訪';
            iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
            iframe.allowFullscreen = true;
            iframe.className = 'w-full h-full';
            iframe.style.border = '0';
            facade.innerHTML = '';
            facade.appendChild(iframe);
        }, { once: true });
    });
</script>
