---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPreview from "../../components/BlogPreview.astro";
import { getCollection, type CollectionEntry } from "astro:content";

// 1. 取得所有文章並依照「置頂」與「日期」排序
const allPosts = (await getCollection("blog")).sort((a, b) => {
    // 條件一：先比對置頂狀態 (featured: true 的排在前面)
    const isAFeatured = a.data.featured === true;
    const isBFeatured = b.data.featured === true;

    if (isAFeatured && !isBFeatured) return -1;
    if (!isAFeatured && isBFeatured) return 1;

    // 條件二：若置頂狀態相同（都是 true 或都是 false），則依照日期排序 (新 -> 舊)
    const dateB = (
        b.data.updatedDate ??
        b.data.lastMod ??
        b.data.pubDate
    ).valueOf();
    const dateA = (
        a.data.updatedDate ??
        a.data.lastMod ??
        a.data.pubDate
    ).valueOf();
    return dateB - dateA;
});

const categories = [
    { id: "all", label: "全部文章" },
    { id: "復健衛教", label: "復健衛教" },
    { id: "特色治療", label: "特色治療" },
    { id: "媒體報導", label: "媒體報導" },
];
---

<BaseLayout
    title="復健醫學與疼痛診療專欄 | 謝明福復健科診所"
    description="為您提供最專業的復健醫學知識、居家保健指南與診所最新動態。"
    ogImage="/images/default-og-image-1200x630.jpg"
    <!-- 若日後有專屬部落格封面圖，換掉這個路徑即可。 -->
>
    <header
        class="bg-gradient-to-br from-primary via-[#004b82] to-primary-dark pt-20 pb-10 mb-10 shadow-inner relative overflow-hidden"
    >
        <div
            class="absolute top-0 left-0 w-full h-full overflow-hidden z-0 opacity-10 pointer-events-none"
        >
            <svg
                class="absolute -top-24 -right-24 w-96 h-96 text-white"
                fill="currentColor"
                viewBox="0 0 100 100"
                ><circle cx="50" cy="50" r="50"></circle></svg
            >
            <svg
                class="absolute top-1/2 -left-12 w-48 h-48 text-white"
                fill="currentColor"
                viewBox="0 0 100 100"
                ><circle cx="50" cy="50" r="50"></circle></svg
            >
        </div>

        <div class="max-w-4xl mx-auto px-4 text-center relative z-10">
            <h1
                class="text-4xl md:text-5xl font-extrabold text-white mb-6 tracking-tight drop-shadow-md"
            >
                復健醫學與疼痛診療專欄
            </h1>
            <p
                class="text-lg md:text-xl text-blue-50 leading-relaxed max-w-2xl mx-auto opacity-90"
            >
                為您提供最專業的復健醫學知識、居家保健指南與診所最新動態。
            </p>
        </div>
    </header>

    <div class="max-w-6xl mx-auto px-3 mb-5 md:mb-5 relative">
        <div class="flex justify-center">
            <div
                id="categories-container"
                class="flex flex-wrap justify-center gap-2 md:gap-3 transition-all duration-300 w-full"
            >
                {
                    categories.map((cat, index) => (
                        <button
                            class={`filter-btn flex flex-wrap justify-center items-center leading-tight flex-1 sm:flex-none max-w-[48%] sm:max-w-none px-3 py-2 md:px-5 md:py-2.5 rounded-xl md:rounded-full text-sm font-semibold transition-all shadow-sm ${index === 0 ? "active bg-primary text-white border border-primary" : "bg-white text-gray-600 border border-gray-200 hover:bg-primary-light hover:text-primary hover:border-primary-light"}`}
                            data-category={cat.id}
                        >
                            <span class="whitespace-nowrap">
                                {cat.label.substring(0, 2)}
                            </span>
                            <span class="whitespace-nowrap">
                                {cat.label.substring(2)}
                            </span>
                        </button>
                    ))
                }
            </div>
        </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 pb-20">
        <div
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8"
            id="post-grid"
        >
            {
                allPosts.map((post) => (
                    <div
                        class="post-item"
                        data-categories={JSON.stringify(
                            post.data.category || [],
                        )}
                    >
                        <BlogPreview post={post} />
                    </div>
                ))
            }
        </div>

        <div id="no-results" class="hidden text-center py-20">
            <div
                class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-100 text-gray-400 mb-4"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="32"
                    height="32"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><circle cx="11" cy="11" r="8"></circle><path
                        d="m21 21-4.3-4.3"></path></svg
                >
            </div>
            <h3 class="text-xl font-bold text-gray-700 mb-2">
                找不到相關分類的文章
            </h3>
            <p class="text-gray-500">
                請嘗試點擊其他分類，或查看「全部文章」。
            </p>
        </div>
    </div>
</BaseLayout>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const filterBtns = document.querySelectorAll(".filter-btn");
        const postItems = document.querySelectorAll(".post-item");
        const noResults = document.getElementById("no-results");

        filterBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                // 按鈕樣式切換
                filterBtns.forEach((b) => {
                    b.classList.remove(
                        "active",
                        "bg-primary",
                        "text-white",
                        "border-primary",
                        "shadow-sm",
                    );
                    b.classList.add(
                        "bg-white",
                        "text-gray-600",
                        "border-gray-200",
                        "font-medium",
                    );
                    b.classList.remove("font-semibold");
                });

                btn.classList.remove(
                    "bg-white",
                    "text-gray-600",
                    "border-gray-200",
                    "font-medium",
                );
                btn.classList.add(
                    "active",
                    "bg-primary",
                    "text-white",
                    "border-primary",
                    "shadow-sm",
                    "font-semibold",
                );

                const selectedCategory = btn.getAttribute("data-category");
                let visibleCount = 0;

                // 篩選文章
                postItems.forEach((item) => {
                    const categories = JSON.parse(
                        item.getAttribute("data-categories") || "[]",
                    );
                    if (
                        selectedCategory === "all" ||
                        categories.includes(selectedCategory)
                    ) {
                        (item as HTMLElement).style.display = "block";
                        (item as HTMLElement).style.animation =
                            "fadeIn 0.5s ease";
                        visibleCount++;
                    } else {
                        (item as HTMLElement).style.display = "none";
                    }
                });

                // 顯示無結果狀態
                if (visibleCount === 0 && noResults) {
                    noResults.classList.remove("hidden");
                } else if (noResults) {
                    noResults.classList.add("hidden");
                }
            });
        });

        // 👇 新增這段：處理 URL Query Parameter (?category=CatName)
        const urlParams = new URLSearchParams(window.location.search);
        const categoryParam = urlParams.get("category");

        if (categoryParam) {
            // Find the button with the matching data-category
            const targetBtn = Array.from(filterBtns).find(
                (btn) => btn.getAttribute("data-category") === categoryParam,
            );

            if (targetBtn) {
                // Simulate click to trigger filtering logic
                (targetBtn as HTMLElement).click();

                // Scroll the button into view (centering it in the horizontal scroll list)
                setTimeout(() => {
                    targetBtn.scrollIntoView({
                        behavior: "smooth",
                        block: "nearest",
                        inline: "center",
                    });
                }, 100);
            }
        }
    });
</script>

<style>
    /* 隱藏橫向滾動條，但保留滑動功能 */
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
