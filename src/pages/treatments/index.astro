---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Treatments from "../../components/Treatments.astro";

const siteUrl = Astro.site?.origin ?? "https://drhsieh-rehab.com";

const breadcrumbSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        { "@type": "ListItem", position: 1, name: "首頁", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "治療項目", item: `${siteUrl}/treatments/` },
    ],
});
---

<BaseLayout
    title="治療項目｜謝明福復健科診所"
    description="謝明福復健科診所提供復健科、疼痛處理、運動醫學等多元治療項目，包含 NEIMS 針極肌肉內電刺激、直線偏極光、關節注射及各類復健療程，由醫師評估後制定個人化方案。"
>
    <slot name="head">
        <script type="application/ld+json" set:html={breadcrumbSchema} />
    </slot>

    <!-- 麵包屑 -->
    <div class="max-w-5xl mx-auto px-4 pt-6">
        <nav aria-label="Breadcrumb" class="text-sm text-gray-500">
            <ol class="flex items-center space-x-2">
                <li><a href="/" class="hover:text-primary transition-colors">首頁</a></li>
                <li><span class="text-gray-400">/</span></li>
                <li><span class="text-gray-800 font-medium" aria-current="page">治療項目</span></li>
            </ol>
        </nav>
    </div>

    <Treatments />
</BaseLayout>
