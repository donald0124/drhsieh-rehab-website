---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CallToAction from "../../components/CallToAction.astro";

const siteUrl = "https://drhsieh-rehab.com";

const pageSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MedicalWebPage",
    "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": `${siteUrl}/conditions/knee-pain/`,
    },
    "headline": "膝蓋退化・退化性關節炎治療｜謝明福復健科診所",
    "description": "膝蓋退化、退化性關節炎、上下樓梯疼痛是中老年族群最常見的復健科主訴。謝明福院長30年經驗，提供玻尿酸注射、直線偏極光等整合性治療。",
    "about": {
        "@type": "MedicalCondition",
        "name": "退化性膝關節炎",
        "alternateName": ["膝蓋退化", "膝關節炎", "膝蓋痛", "關節積水", "髕骨軟化症"],
        "description": "退化性膝關節炎是中老年族群最常見的關節疾病，以關節軟骨磨損為主要病理機制，導致膝蓋疼痛、僵硬與功能下降。",
        "possibleTreatment": [
            { "@type": "MedicalTherapy", "name": "關節玻尿酸注射" },
            { "@type": "MedicalTherapy", "name": "直線偏極光治療 (SuperLizer)" },
            { "@type": "MedicalTherapy", "name": "針極肌肉內電刺激 (NEIMS)" },
            { "@type": "MedicalTherapy", "name": "物理治療" },
        ],
    },
    "author": {
        "@type": "Person",
        "@id": `${siteUrl}/#doctor`,
        "name": "謝明福",
        "jobTitle": "復健科主治醫師、院長",
    },
    "publisher": {
        "@type": "MedicalOrganization",
        "name": "謝明福復健科診所",
        "@id": `${siteUrl}/#clinic`,
    },
});

const breadcrumbSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        { "@type": "ListItem", position: 1, name: "首頁", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "常見症狀", item: `${siteUrl}/#services` },
        { "@type": "ListItem", position: 3, name: "膝蓋退化・退化性關節炎", item: `${siteUrl}/conditions/knee-pain/` },
    ],
});

const faqSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": "膝蓋退化要看哪一科？",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "膝蓋退化建議先就診「復健科」。復健科醫師能評估退化程度、規劃保守治療（物理治療、注射、NEIMS），並判斷是否需轉介骨科手術評估。",
            },
        },
        {
            "@type": "Question",
            "name": "退化性關節炎打玻尿酸有用嗎？",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "關節玻尿酸注射可補充關節潤滑液、緩解疼痛、改善活動度，對中度退化的患者效果較明顯。效果因個人狀況而異，通常需重複施打。實際適應症及效益須由醫師評估後決定。",
            },
        },
        {
            "@type": "Question",
            "name": "膝蓋退化一定要換人工關節嗎？",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "大多數退化性膝關節炎可透過保守治療（物理治療、注射、NEIMS、SuperLizer等）延緩退化進程並維持生活品質，不一定需要手術。手術通常是保守治療無效、退化嚴重（末期）且嚴重影響生活功能時的最後選項。",
            },
        },
        {
            "@type": "Question",
            "name": "膝蓋退化健保有給付嗎？",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "一般物理治療在醫師處方下可申請健保給付。玻尿酸注射、直線偏極光（SuperLizer）、NEIMS 屬自費項目。健保對玻尿酸注射有特定給付條件，請洽詢醫師確認。",
            },
        },
        {
            "@type": "Question",
            "name": "需要預約嗎？",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "本診所一律採現場掛號，不提供預約。請於門診時間內直接至診所報到，初診請於門診結束前 20 分鐘前報到。",
            },
        },
    ],
});

const howtoSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "如何在謝明福復健科診所就診（膝蓋痛）",
    "description": "謝明福復健科診所（新北市三峽）就診流程：現場掛號、院長親自評估、安排個人化復健療程、追蹤調整。",
    "step": [
        {
            "@type": "HowToStep",
            "position": 1,
            "name": "現場掛號（門診）",
            "text": "本診所不提供預約，請於門診時間內直接至診所現場掛號。初診請於門診結束前 20 分鐘前報到。",
        },
        {
            "@type": "HowToStep",
            "position": 2,
            "name": "謝明福院長親自評估",
            "text": "院長透過問診、觸診與理學檢查（關節活動度、肌力測試、膝關節特殊測試），判斷膝蓋問題的真正病因。如有需要，院長會建議適當的影像學檢查協助診斷。",
        },
        {
            "@type": "HowToStep",
            "position": 3,
            "name": "安排復健療程",
            "text": "依評估結果，院長規劃個人化治療組合：可能包含物理治療、玻尿酸注射、NEIMS、直線偏極光，或其他注射治療。首次就診通常當天即可開始復健。",
        },
        {
            "@type": "HowToStep",
            "position": 4,
            "name": "追蹤與調整",
            "text": "複診時院長再次評估症狀改善狀況，動態調整治療計畫。院長也會提供日常保護膝蓋的衛教建議（如體重管理、正確蹲跪姿勢），以減少退化加速。",
        },
    ],
});
---

<BaseLayout
    title="膝蓋退化・退化性關節炎治療｜謝明福復健科診所（三峽）"
    description="上下樓梯膝蓋痛、退化性關節炎？謝明福院長30年復健科經驗，提供玻尿酸注射、NEIMS、直線偏極光整合治療，延緩退化、改善功能。新北市三峽，現場掛號即可就診。"
    ogType="website"
>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={pageSchema} />
        <script type="application/ld+json" set:html={breadcrumbSchema} />
        <script type="application/ld+json" set:html={faqSchema} />
        <script type="application/ld+json" set:html={howtoSchema} />
    </Fragment>

    <!-- Breadcrumb -->
    <div class="max-w-4xl mx-auto px-4 pt-8">
        <nav aria-label="Breadcrumb" class="text-sm text-gray-500">
            <ol class="flex items-center space-x-2">
                <li><a href="/" class="hover:text-primary transition-colors">首頁</a></li>
                <li><span class="text-gray-400">/</span></li>
                <li><a href="/#services" class="hover:text-primary transition-colors">常見症狀</a></li>
                <li><span class="text-gray-400">/</span></li>
                <li><span class="text-gray-800 font-medium" aria-current="page">膝蓋退化・退化性關節炎</span></li>
            </ol>
        </nav>
    </div>

    <!-- Hero -->
    <header class="max-w-4xl mx-auto px-4 pt-8 pb-12 text-center">
        <div class="inline-flex items-center gap-2 bg-rose-50 text-rose-700 text-sm font-semibold px-4 py-1.5 rounded-full mb-6">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            復健科常見主訴
        </div>
        <h1 class="text-3xl md:text-5xl font-extrabold text-heading leading-tight mb-4">
            膝蓋退化・退化性關節炎
        </h1>
        <p class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
            上下樓梯膝蓋痛、蹲下困難、關節僵硬……膝關節退化是中老年族群最常見的活動障礙。謝明福院長透過整合性治療，協助延緩退化進程、恢復日常功能。
        </p>

        <!-- 相關症狀標籤 -->
        <div class="flex flex-wrap justify-center gap-2 mt-6">
            {[
                "膝蓋退化",
                "退化性關節炎",
                "上下樓梯痛",
                "關節積水",
                "髕骨軟化症",
                "膝蓋僵硬",
                "蹲下困難",
                "O型腿",
                "膝關節炎",
            ].map((tag) => (
                <span class="bg-rose-50 text-rose-800 text-sm px-3 py-1 rounded-full border border-rose-100">
                    {tag}
                </span>
            ))}
        </div>
    </header>

    <main id="main-content" class="max-w-4xl mx-auto px-4 pb-16 space-y-16">

        <!-- 醫療聲明 -->
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-5 text-base text-amber-800 leading-relaxed">
            <strong>醫療聲明：</strong>本頁內容僅供一般衛教資訊參考，不涉及任何療效保證或治癒承諾。實際病因、適應症與治療計畫，須由謝明福院長親自問診評估後決定。
        </div>

        <!-- 您是否有以下症狀 -->
        <section aria-labelledby="symptoms">
            <h2 id="symptoms" class="text-2xl md:text-3xl font-bold text-heading mb-6">
                您是否有以下困擾？
            </h2>
            <div class="grid sm:grid-cols-2 gap-3">
                {[
                    "上下樓梯時膝蓋疼痛，下樓尤其明顯",
                    "長時間坐著站起來時，膝蓋僵硬、需要走幾步才比較順",
                    "膝蓋彎曲時有摩擦聲或「喀喀」聲",
                    "走路走多了，膝蓋疼痛加劇，需要休息才能繼續",
                    "蹲下、跪地越來越困難，影響日常生活",
                    "膝蓋有時腫脹、積水，或感覺有液體在裡面",
                    "膝蓋無力，有時感覺快軟掉或「膝蓋快掉出來」",
                    "天氣變化（濕冷）時膝蓋特別不舒服",
                ].map((symptom) => (
                    <div class="flex items-start gap-3 bg-white border border-gray-100 rounded-xl p-4 shadow-sm">
                        <span class="w-5 h-5 rounded-full bg-rose-100 text-rose-700 flex items-center justify-center flex-shrink-0 text-xs font-bold mt-0.5">✓</span>
                        <span class="text-base text-gray-700 leading-relaxed">{symptom}</span>
                    </div>
                ))}
            </div>
            <p class="text-sm text-gray-500 mt-4 text-center">
                若有上述症狀，建議由復健科醫師評估，了解退化程度與最適合的治療方向。
            </p>
        </section>

        <!-- 常見病因 -->
        <section aria-labelledby="causes">
            <h2 id="causes" class="text-2xl md:text-3xl font-bold text-heading mb-2">
                常見病因診斷
            </h2>
            <p class="text-gray-500 mb-8 text-base">
                「膝蓋痛」原因多元，需醫師評估才能確認是否為退化性關節炎，以及退化的程度。
            </p>
            <div class="grid sm:grid-cols-2 gap-4">
                {[
                    {
                        title: "退化性膝關節炎",
                        desc: "關節軟骨隨年齡或長期過度使用而磨損，是最常見的膝蓋問題。輕中度可保守治療，重度才考慮手術。X光可輔助評估退化程度。",
                        tags: ["中老年族群", "軟骨磨損", "上下樓梯痛"],
                    },
                    {
                        title: "髕骨軟化症（跑者膝）",
                        desc: "髕骨（膝蓋骨）下方軟骨損傷，上下樓梯或久坐後站起時疼痛，好發於年輕族群、跑步者或長時間屈膝工作者。",
                        tags: ["年輕族群", "膝蓋骨痛", "久坐後加重"],
                    },
                    {
                        title: "關節積水",
                        desc: "關節腔因發炎積聚液體，造成膝蓋腫脹感、活動受限。可能是退化性關節炎、痛風或其他炎症的表現，需進一步評估。",
                        tags: ["膝蓋腫脹", "活動受限", "需進一步評估"],
                    },
                    {
                        title: "鵝掌足滑囊炎",
                        desc: "膝關節內下方的滑囊發炎，造成膝蓋內側下方疼痛，常與退化性關節炎並存，觸診可鑑別。",
                        tags: ["膝內側痛", "下樓梯明顯", "常合併退化"],
                    },
                    {
                        title: "內側皺褶症候群",
                        desc: "膝關節內側的黏膜皺褶增厚發炎，彎曲伸直時有雜音或夾擠感，好發於年輕活躍族群，常被誤認為半月板問題。",
                        tags: ["彎曲有聲", "膝內側夾擠", "年輕族群"],
                    },
                    {
                        title: "貝氏囊腫",
                        desc: "膝蓋後側（膕窩）出現的囊性腫塊，由關節液外漏積聚形成，常與膝關節內部問題（退化、半月板損傷）有關。",
                        tags: ["膝後腫塊", "蹲下不舒服", "與關節病變有關"],
                    },
                ].map((item) => (
                    <div class="bg-white border border-gray-100 rounded-xl p-5 shadow-sm">
                        <h3 class="font-bold text-gray-800 mb-2 flex items-center gap-2 text-lg">
                            <span class="w-2 h-2 rounded-full bg-rose-500 flex-shrink-0" />
                            {item.title}
                        </h3>
                        <p class="text-base text-gray-600 leading-relaxed mb-3">{item.desc}</p>
                        <div class="flex flex-wrap gap-1.5">
                            {item.tags.map((tag) => (
                                <span class="text-xs bg-rose-50 text-rose-700 px-2 py-0.5 rounded-full border border-rose-100">{tag}</span>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- 診所評估與治療方向 -->
        <section aria-labelledby="treatments">
            <h2 id="treatments" class="text-2xl md:text-3xl font-bold text-heading mb-2">
                謝明福診所的評估與治療方向
            </h2>
            <p class="text-gray-500 mb-8 text-base">
                院長透過理學檢查（關節活動度、肌力評估、膝關節特殊測試）找出病因後，再決定最合適的治療組合。
            </p>

            <div class="space-y-4">
                <!-- 玻尿酸注射 -->
                <div class="bg-white border border-teal-100 rounded-xl p-6 shadow-sm">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center text-teal-600 flex-shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                            </svg>
                        </div>
                        <div class="flex-1">
                            <h3 class="font-bold text-gray-800 text-lg mb-1">
                                關節玻尿酸注射
                                <span class="ml-2 text-xs font-normal bg-teal-50 text-teal-700 px-2 py-0.5 rounded-full border border-teal-100">院長特色治療</span>
                            </h3>
                            <p class="text-base text-gray-600 leading-relaxed">
                                補充膝關節腔內的玻尿酸，恢復關節潤滑功能，減少骨面摩擦、緩解疼痛並改善活動度。適用於中度退化性膝關節炎患者，由院長親自執行注射。
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Superlizer -->
                <div class="bg-white border border-orange-100 rounded-xl p-6 shadow-sm">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-orange-50 rounded-xl flex items-center justify-center text-orange-500 flex-shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
                            </svg>
                        </div>
                        <div class="flex-1">
                            <h3 class="font-bold text-gray-800 text-lg mb-1">
                                直線偏極光治療（SuperLizer）
                                <span class="ml-2 text-xs font-normal bg-orange-50 text-orange-600 px-2 py-0.5 rounded-full border border-orange-100">院長特色治療</span>
                            </h3>
                            <p class="text-base text-gray-600 leading-relaxed mb-3">
                                近紅外線光療穿透膝關節周圍軟組織，促進消炎與修復，對膝關節滑囊炎、韌帶慢性發炎、術後組織修復有良好輔助效果。非侵入性、無痛。
                            </p>
                            <a
                                href="/treatments/superlizer/"
                                class="inline-flex items-center gap-1.5 text-sm text-orange-500 font-semibold hover:underline"
                                aria-label="了解直線偏極光治療的方式"
                            >
                                了解直線偏極光治療方式 →
                            </a>
                        </div>
                    </div>
                </div>

                <!-- NEIMS + 物理治療 -->
                <div class="bg-white border border-blue-100 rounded-xl p-6 shadow-sm">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-primary flex-shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                            </svg>
                        </div>
                        <div class="flex-1">
                            <h3 class="font-bold text-gray-800 text-lg mb-1">
                                NEIMS 與物理治療
                                <span class="ml-2 text-xs font-normal bg-blue-50 text-primary px-2 py-0.5 rounded-full border border-blue-100">院長特色治療</span>
                            </h3>
                            <p class="text-base text-gray-600 leading-relaxed mb-3">
                                NEIMS 可針對膝關節周圍肌筋膜激痛點（如股四頭肌、腿後肌群）進行深層電刺激，改善肌肉緊繃對膝關節的壓力。搭配物理治療（電療、熱療、超音波）進行整合性復健。
                            </p>
                            <a
                                href="/treatments/neims/"
                                class="inline-flex items-center gap-1.5 text-sm text-primary font-semibold hover:underline"
