---
// 1. 匯入我們剛建立的版型
import BaseLayout from "../layouts/BaseLayout.astro";
import Services from "../components/Services.astro";
import QA from "../components/QA.astro";
import Patientinfo from "../components/Patientinfo.astro";
import Hero from "../components/Hero.astro";
import AboutUs from "../components/AboutUs.astro";
import Team from "../components/Team.astro";
import HomeBlogSection from "../components/HomeBlogSection.astro";
// import PostWall from '../components/PostWall.astro';
//import AnnouncementBanner from "../components/AnnouncementBanner.astro";

// 2. 定義這個頁面的 SEO 資訊 (來自您的檔案)
const pageTitle =
    "謝明福復健科診所｜三峽鶯歌專業疼痛治療、運動傷害、肌筋膜炎與骨科術後復健";
const pageDesc =
    "三峽、鶯歌復健推薦｜謝明福院長30年經驗，專精針極肌肉內電刺激、疼痛治療、物理治療，專業診斷治療肌筋膜炎、運動傷害。提供專業、親切的復健醫療環境，協助您遠離長期痠痛。";
---

<BaseLayout title={pageTitle} description={pageDesc}>
    <!-- <AnnouncementBanner /> -->
    <Hero />
    <AboutUs />
    <Team />
    <Services />
    <HomeBlogSection />
    <Patientinfo />
    <!-- <PostWall limit={3} /> -->
</BaseLayout>
