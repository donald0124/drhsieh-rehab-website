---
// 1. 匯入我們剛建立的版型
import BaseLayout from "../layouts/BaseLayout.astro";
import Services from "../components/Services.astro";
import QA from "../components/QA.astro";
import Patientinfo from "../components/Patientinfo.astro";
import Hero from "../components/Hero.astro";
import AboutUs from "../components/AboutUs.astro";
import Team from "../components/Team.astro";
import HomeBlogSection from "../components/HomeBlogSection.astro";
import Treatments from "../components/Treatments.astro";
// import PostWall from '../components/PostWall.astro';

// 2. 定義這個頁面的 SEO 資訊 (來自您的檔案)
const pageTitle =
    "謝明福復健科診所｜三峽鶯歌北大專業疼痛治療、運動傷害、肌筋膜炎與骨科術後復健";
const pageDesc =
    "三峽鶯歌復健科推薦。謝明福院長30年經驗，專長肌筋膜炎、肩頸痛、腰背痛、膝痛與手麻評估治療，提供物理治療、NEIMS與術後復健整合照護。";
---

<BaseLayout title={pageTitle} description={pageDesc}>
    <Hero />
    <AboutUs />
    <Team />
    <Services />
    <Treatments />
    <HomeBlogSection />
    <Patientinfo />
    <!-- <PostWall limit={3} /> -->
</BaseLayout>
